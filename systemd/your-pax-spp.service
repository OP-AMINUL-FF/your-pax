[Unit]
Description=Your-Pax Bluetooth Serial Server (SPP/RFCOMM)
After=bluetooth.service
Requires=bluetooth.service

[Service]
ExecStart=/usr/bin/python3 __YOUR_PAX_DIR__/bt_serial_server.py
WorkingDirectory=__YOUR_PAX_DIR__
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
