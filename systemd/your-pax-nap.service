[Unit]
Description=Your-Pax Bluetooth NAP Bridge
After=bluetooth.service
Requires=bluetooth.service
Before=your-pax-web.service

[Service]
ExecStart=/usr/bin/python3 __YOUR_PAX_DIR__/actions/bluetooth_nap.py
WorkingDirectory=__YOUR_PAX_DIR__
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
